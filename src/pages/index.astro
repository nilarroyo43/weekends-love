---
import Layout from "../layouts/Layout.astro";
import SplashScreen from "../components/Splash.astro"; // 1. Importamos el componente
import { getEntry } from "astro:content";

const id_finde = "14-03-2026"; // Cambia esto por el ID de tu JSON
const plan = await getEntry("findes", id_finde);
// 2. Extraemos 'imagens_splash' de tu JSON
const { titulo, fecha, imagens_splash } = plan.data;
---

<Layout title="Nuestra Cápsula">
  <SplashScreen imagen={imagens_splash} />

  <main
    class="min-h-screen flex flex-col items-center justify-center p-6 text-center bg-gradient-to-b from-[#1F1512] to-[#2E1D18]"
  >
    <h1
      class="text-4xl font-extrabold mb-4 text-transparent bg-clip-text bg-gradient-to-r from-orange-300 to-rose-300"
    >
      {titulo}
    </h1>
    <p class="text-orange-200/70 mb-10 tracking-wide font-medium">
      La espera casi termina...
    </p>

    <div
      id="countdown"
      data-fecha={fecha}
      class="flex gap-4 text-2xl font-mono bg-[#3D251E]/50 backdrop-blur-md p-6 rounded-3xl shadow-2xl shadow-orange-900/20 mb-12 border border-orange-500/20"
    >
      <div class="flex flex-col">
        <span id="days" class="text-orange-100">00</span><span
          class="text-xs text-orange-300/60 uppercase font-sans mt-1"
          >Días</span>
      </div><span class="text-orange-500/50">:</span>
      <div class="flex flex-col">
        <span id="hours" class="text-orange-100">00</span><span
          class="text-xs text-orange-300/60 uppercase font-sans mt-1">Hrs</span>
      </div><span class="text-orange-500/50">:</span>
      <div class="flex flex-col">
        <span id="mins" class="text-orange-100">00</span><span
          class="text-xs text-orange-300/60 uppercase font-sans mt-1">Min</span>
      </div><span class="text-orange-500/50">:</span>
      <div class="flex flex-col">
        <span id="secs" class="text-orange-100">00</span><span
          class="text-xs text-orange-300/60 uppercase font-sans mt-1">Seg</span>
      </div>
    </div>

    <a
      href={`/plan/${plan.id}`}
      class="inline-block animate-latido px-8 py-4 bg-gradient-to-r from-orange-400 to-rose-400 text-white rounded-full font-bold shadow-xl shadow-orange-500/40 transition-all hover:shadow-orange-500/60"
    >
      ¿Qué haremos este finde? ✨
    </a>

    <a
      href="/recuerdos"
      class="mt-14 text-orange-300/50 hover:text-orange-300 transition-colors text-sm uppercase tracking-widest font-bold"
    >
      Nuestros recuerdos 📖
    </a>
  </main>
</Layout>

<style>
  .animate-latido {
    animation: latido 2.5s cubic-bezier(0.4, 0, 0.6, 1) infinite;
  }
  @keyframes latido {
    0%,
    100% {
      transform: scale(1);
    }
    15% {
      transform: scale(1.08);
    }
    30% {
      transform: scale(1);
    }
    45% {
      transform: scale(1.08);
    }
    60% {
      transform: scale(1);
    }
  }
</style>

<script>
  function initCountdown() {
    const countdownElement = document.getElementById("countdown");
    if (!countdownElement) return;

    const fechaString = countdownElement.getAttribute("data-fecha");
    const targetDate = new Date(fechaString).getTime();

    const updateTimer = () => {
      const now = new Date().getTime();
      const distance = targetDate - now;

      if (distance < 0) {
        document.getElementById("days").innerText = "00";
        document.getElementById("hours").innerText = "00";
        document.getElementById("mins").innerText = "00";
        document.getElementById("secs").innerText = "00";
        return;
      }

      const days = Math.floor(distance / (1000 * 60 * 60 * 24));
      const hours = Math.floor(
        (distance % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60),
      );
      const minutes = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
      const seconds = Math.floor((distance % (1000 * 60)) / 1000);

      document.getElementById("days").innerText = days
        .toString()
        .padStart(2, "0");
      document.getElementById("hours").innerText = hours
        .toString()
        .padStart(2, "0");
      document.getElementById("mins").innerText = minutes
        .toString()
        .padStart(2, "0");
      document.getElementById("secs").innerText = seconds
        .toString()
        .padStart(2, "0");
    };

    setInterval(updateTimer, 1000);
    updateTimer();
  }

  initCountdown();
</script>
