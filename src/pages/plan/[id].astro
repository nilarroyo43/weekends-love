---
import Layout from "../../layouts/Layout.astro";
import GiftButton from "../../components/GiftButton.astro";
import StorySlide from "../../components/StorySlide.astro";
import { getCollection } from "astro:content";

export async function getStaticPaths() {
  const todosLosFindes = await getCollection("findes");
  return todosLosFindes.map((plan) => ({
    params: { id: plan.id },
    props: { plan },
  }));
}

const { plan } = Astro.props;
const {
  actividades,
  comida,
  peliculas,
  img_circulo_actividades,
  img_circulo_comida,
  img_circulo_peliculas,
} = plan.data;
---

<Layout title="El Plan">
  <main id="menu-categorias" class="min-h-screen flex flex-col items-center justify-center p-6 text-center relative overflow-hidden">
    
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_center,_var(--tw-gradient-stops))] from-orange-200/40 via-orange-50 to-orange-50 -z-10"></div>
    
    <a href="/" class="absolute top-6 left-6 text-orange-500 hover:text-rose-500 transition-colors z-50 uppercase tracking-[0.2em] text-xs font-bold">← Volver</a>
    
    <h1 transition:name="titulo-plan" class="text-4xl md:text-5xl font-black md:mb-8 text-orange-950 uppercase tracking-tighter drop-shadow-sm mt-12 md:mt-0">Descubre el plan...</h1>
    
    <div class="flex flex-col md:flex-row items-center justify-center gap-32 md:gap-40 w-full max-w-7xl mx-auto mt-16 md:mt-12">
      
      <div class="md:mt-48">
        <GiftButton categoria="actividades" imagen={img_circulo_actividades} label="Planes" colorBorde="border-emerald-200 shadow-emerald-200/50" />
      </div>
      
      <div class="md:-mt-24">
        <GiftButton categoria="comida" imagen={img_circulo_comida} label="Comida" colorBorde="border-orange-200 shadow-orange-200/50" />
      </div>
      
      <div class="md:mt-48">
        <GiftButton categoria="peliculas" imagen={img_circulo_peliculas} label="Cine" colorBorde="border-purple-200 shadow-purple-200/50" />
      </div>

    </div>
  </main>

  <div id="view-actividades" class="story-view hidden fixed inset-0 z-50 bg-orange-50">
    {actividades.map((act, i) => (
      <StorySlide index={i} categoria="actividades" etiqueta={act.tipo} titulo={act.desc} detalle={act.detalle} imagen={act.imagen || img_circulo_actividades} colorTexto="text-emerald-400" colorFondo="bg-emerald-900/10" />
    ))}
  </div>

  <div id="view-comida" class="story-view hidden fixed inset-0 z-50 bg-orange-50">
    {comida.map((com, i) => (
      <StorySlide index={i} categoria="comida" etiqueta={com.momento} titulo={com.lugar} detalle={com.detalle} imagen={com.imagen || img_circulo_comida} linkMapa={com.ubicacion} colorTexto="text-orange-400" colorFondo="bg-orange-900/10" />
    ))}
  </div>

  <div id="view-peliculas" class="story-view hidden fixed inset-0 z-50 bg-orange-50">
    {peliculas.map((peli, i) => (
      <StorySlide index={i} categoria="peliculas" etiqueta={peli.momento} titulo={peli.pelicula} detalle={peli.detalle} imagen={peli.url_cartel} colorTexto="text-purple-400" colorFondo="bg-purple-900/10" />
    ))}
  </div>
</Layout>

<script>
  document.addEventListener('astro:page-load', () => {
    const estadoRegalos = { actividades: false, comida: false, peliculas: false };
    const menuCategorias = document.getElementById('menu-categorias');

    document.querySelectorAll('.categoria-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const categoria = btn.getAttribute('data-categoria');
        const tapa = btn.querySelector('.regalo-tapa');

        if (!estadoRegalos[categoria]) {
          // PRIMER CLIC: Animación Fancy (Pop)
          tapa.classList.remove('group-hover:-rotate-3', 'group-hover:scale-105', 'transition-transform', 'duration-700', 'ease-[cubic-bezier(0.34,1.56,0.64,1)]');
          tapa.classList.add('animate-regalo-pop');
          estadoRegalos[categoria] = true;

          setTimeout(() => {
            if (tapa) tapa.style.display = 'none';
          }, 900);

          const imagenFondo = btn.querySelector('img');
          if (imagenFondo) {
            imagenFondo.style.viewTransitionName = `img-${categoria}`;
          }

        } else {
          // SEGUNDO CLIC: Entrar en la story
          abrirStory(categoria);
        }
      });
    });

    function abrirStory(categoria) {
      const vista = document.getElementById(`view-${categoria}`);
      const slides = vista.querySelectorAll('.story-slide');
      if (slides.length === 0) return;

      const ejecutarCambioDOM = () => {
        menuCategorias.classList.add('hidden');
        vista.classList.remove('hidden');

        slides.forEach(s => { s.classList.add('hidden'); s.classList.remove('flex'); });
        
        slides[0].classList.remove('hidden');
        slides[0].classList.add('flex');
      };

      if (document.startViewTransition) {
        document.startViewTransition(() => ejecutarCambioDOM());
      } else {
        ejecutarCambioDOM();
      }

      let currentSlide = 0;
      const avanzarSlide = (e) => {
        if(e.target.tagName.toLowerCase() === 'a') return;

        currentSlide++;
        if (currentSlide < slides.length) {
          if (document.startViewTransition) {
            document.startViewTransition(() => {
              slides[currentSlide - 1].classList.add('hidden');
              slides[currentSlide - 1].classList.remove('flex');
              slides[currentSlide].classList.remove('hidden');
              slides[currentSlide].classList.add('flex');
            });
          }
        } else {
          vista.removeEventListener('click', avanzarSlide);
          if (document.startViewTransition) {
            document.startViewTransition(() => {
              vista.classList.add('hidden');
              menuCategorias.classList.remove('hidden');
            });
          }
        }
      };

      vista.addEventListener('click', avanzarSlide);
    }
  });
</script>

<style is:global>
  /* Hacemos que TODAS las View Transitions sean suaves, lentas y fluidas */
  ::view-transition-group(*) {
    animation-duration: 0.8s;
    animation-timing-function: cubic-bezier(0.16, 1, 0.3, 1);
  }
  /* Animación Fancy para la tapa (Squash and Stretch -> Vuelo) */
  .animate-regalo-pop {
    animation: regalo-pop 0.9s cubic-bezier(0.25, 1, 0.5, 1) forwards;
  }
  
  @keyframes regalo-pop {
    0%   { transform: scale(1) translateY(0) rotate(0); opacity: 1; }
    20%  { transform: scale(1.1, 0.9) translateY(15px) rotate(-8deg); opacity: 1; } /* Se aplasta (coge impulso) */
    45%  { transform: scale(0.95, 1.1) translateY(-60px) rotate(15deg); opacity: 1; } /* Salta hacia arriba */
    100% { transform: scale(1.4) translateY(-400px) rotate(60deg); opacity: 0; pointer-events: none; } /* Vuela y desaparece */
  }
</style>