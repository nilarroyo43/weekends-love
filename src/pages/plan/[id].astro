---
import Layout from '../../layouts/Layout.astro';
import GiftButton from '../../components/GiftButton.astro';
import StorySlide from '../../components/StorySlide.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const todosLosFindes = await getCollection('findes');
  return todosLosFindes.map((plan) => ({
    params: { id: plan.id },
    props: { plan },
  }));
}

const { plan } = Astro.props;
const { actividades, comida, peliculas, img_circulo_actividades, img_circulo_comida, img_circulo_peliculas } = plan.data;
---

<Layout title="El Plan">
  <main id="menu-categorias" class="min-h-screen flex flex-col items-center justify-center p-6 text-center relative overflow-hidden">
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_center,_var(--tw-gradient-stops))] from-rose-900/10 via-[#0a0a0a] to-[#0a0a0a] -z-10"></div>
    
    <a href="/" class="absolute top-6 left-6 text-gray-500 hover:text-rose-400 transition-colors z-50 uppercase tracking-widest text-xs font-bold">← Volver al inicio</a>
    
    <h1 class="text-3xl md:text-4xl font-bold mb-16 text-transparent bg-clip-text bg-gradient-to-r from-rose-400 to-orange-300">Descubre el plan...</h1>
    
    <div class="flex flex-col md:flex-row gap-16 md:gap-10">
      <GiftButton categoria="actividades" imagen={img_circulo_actividades} label="Planes" colorBorde="border-emerald-500 shadow-emerald-500/20" />
      <GiftButton categoria="comida" imagen={img_circulo_comida} label="Comida" colorBorde="border-orange-500 shadow-orange-500/20" />
      <GiftButton categoria="peliculas" imagen={img_circulo_peliculas} label="Cine" colorBorde="border-purple-500 shadow-purple-500/20" />
    </div>
  </main>

  <div id="view-actividades" class="story-view hidden fixed inset-0 z-50 bg-[#0a0a0a]">
    {actividades.map((act, i) => (
      <StorySlide index={i} etiqueta={act.tipo} titulo={act.desc} imagen={act.imagen || img_circulo_actividades} colorTexto="text-emerald-400" colorFondo="bg-emerald-900/10" />
    ))}
  </div>

  <div id="view-comida" class="story-view hidden fixed inset-0 z-50 bg-[#0a0a0a]">
    {comida.map((com, i) => (
      <StorySlide index={i} etiqueta={com.momento} titulo={com.lugar} imagen={com.imagen || img_circulo_comida} linkMapa={com.ubicacion} colorTexto="text-orange-400" colorFondo="bg-orange-900/10" />
    ))}
  </div>

  <div id="view-peliculas" class="story-view hidden fixed inset-0 z-50 bg-[#0a0a0a]">
    {peliculas.map((peli, i) => (
      <StorySlide index={i} etiqueta={peli.momento} titulo={peli.pelicula} imagen={peli.url_cartel} colorTexto="text-purple-400" colorFondo="bg-purple-900/10" />
    ))}
  </div>
</Layout>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const estadoRegalos = { actividades: false, comida: false, peliculas: false };
    const menuCategorias = document.getElementById('menu-categorias');

    document.querySelectorAll('.categoria-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const categoria = btn.getAttribute('data-categoria');
        const tapa = btn.querySelector('.regalo-tapa');

        if (!estadoRegalos[categoria]) {
          // PRIMER CLIC: Volar la tapa con la nueva clase CSS
          tapa.classList.add('tapa-abierta');
          estadoRegalos[categoria] = true;
        } else {
          // SEGUNDO CLIC: Entrar en la story
          abrirStory(categoria);
        }
      });
    });

    function abrirStory(categoria) {
      const vista = document.getElementById(`view-${categoria}`);
      const slides = vista.querySelectorAll('.story-slide');
      if (slides.length === 0) return;

      menuCategorias.classList.add('hidden');
      vista.classList.remove('hidden');

      let currentSlide = 0;
      
      // Función para resetear y mostrar slide (para que se repita la animación de entrada)
      const mostrarSlide = (index) => {
        slides.forEach(s => {
          s.classList.add('hidden');
          s.classList.remove('flex');
        });
        slides[index].classList.remove('hidden');
        // Usamos flex para que Tailwind respete la estructura
        slides[index].classList.add('flex'); 
      };

      mostrarSlide(0);

      const avanzarSlide = (e) => {
        if(e.target.tagName.toLowerCase() === 'a') return; // No avanzar si clica en un link

        currentSlide++;
        if (currentSlide < slides.length) {
          mostrarSlide(currentSlide);
        } else {
          // Fin: Volver al menú
          vista.removeEventListener('click', avanzarSlide);
          vista.classList.add('hidden');
          menuCategorias.classList.remove('hidden');
        }
      };

      vista.addEventListener('click', avanzarSlide);
    }
  });
</script>