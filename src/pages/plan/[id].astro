---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

// 1. Le decimos a Astro que cree una página por cada archivo JSON que exista
export async function getStaticPaths() {
  const todosLosFindes = await getCollection('findes');
  return todosLosFindes.map((plan) => ({
    params: { id: plan.id },
    props: { plan },
  }));
}

// 2. Extraemos los datos del plan actual
const { plan } = Astro.props;
const { actividades, comida, peliculas } = plan.data;
---

<Layout title="El Plan">
  <div class="flex overflow-x-auto snap-x snap-mandatory h-screen w-full relative">
    
    <a href="/" class="fixed top-6 left-6 z-50 bg-black/50 text-white p-3 rounded-full backdrop-blur-md">
      ← Volver
    </a>

    {actividades.map((act) => (
      <div class="snap-center shrink-0 w-screen h-screen flex flex-col justify-end p-8 pb-24 border-r border-gray-800 bg-emerald-900/20">
        <span class="text-emerald-400 font-bold uppercase tracking-widest text-sm mb-2">{act.tipo}</span>
        <h2 class="text-4xl font-bold mb-4">{act.desc}</h2>
      </div>
    ))}

    {comida.map((com) => (
      <div class="snap-center shrink-0 w-screen h-screen flex flex-col justify-end p-8 pb-24 border-r border-gray-800 bg-orange-900/20">
        <span class="text-orange-400 font-bold uppercase tracking-widest text-sm mb-2">{com.momento}</span>
        <h2 class="text-4xl font-bold mb-4">{com.lugar}</h2>
        <a href={com.ubicacion} target="_blank" class="text-orange-300 underline mt-2">📍 Ver en el mapa</a>
      </div>
    ))}

    {peliculas.map((peli) => (
      <div class="snap-center shrink-0 w-screen h-screen flex flex-col justify-end p-8 pb-24 bg-purple-900/20">
        <span class="text-purple-400 font-bold uppercase tracking-widest text-sm mb-2">{peli.momento}</span>
        <h2 class="text-4xl font-bold mb-4">🍿 {peli.pelicula}</h2>
      </div>
    ))}

  </div>
</Layout>