---
interface Props {
  index: number;
  etiqueta: string;
  titulo: string;
  imagen: string;
  colorTexto: string;
  colorFondo: string;
  linkMapa?: string;
}

// Sobrescribimos el colorFondo para que todo tenga esa vibra pastel/naranja cálida
const { index, etiqueta, titulo, imagen, linkMapa } = Astro.props;
---

<div class="story-slide hidden absolute inset-0 flex-col md:flex-row cursor-pointer animate-story-in" data-index={index}>
  
  <div class="w-full md:w-1/2 h-1/2 md:h-full p-10 flex flex-col justify-center border-b md:border-b-0 md:border-r border-orange-900/30 bg-[#2A1A14]/90 backdrop-blur-md">
    
    <span class="text-orange-300 font-bold uppercase tracking-widest text-sm mb-3 drop-shadow-md">
      {etiqueta}
    </span>
    
    <h2 class="text-4xl md:text-6xl font-extrabold mb-6 leading-tight text-orange-50 drop-shadow-lg">
      {titulo}
    </h2>
    
    {linkMapa && (
      <a href={linkMapa} target="_blank" class="inline-block mt-2 px-6 py-3 bg-orange-500/20 hover:bg-orange-500/40 border border-orange-500/30 text-orange-100 font-bold rounded-2xl w-max transition-all hover:scale-105 backdrop-blur-md">
        📍 Abrir en Maps
      </a>
    )}
    
    <p class="text-orange-300/50 mt-auto text-sm animate-pulse tracking-wide uppercase font-medium">Toca para continuar →</p>
  </div>

  <div class="w-full md:w-1/2 h-1/2 md:h-full relative overflow-hidden">
    <img src={imagen} class="absolute inset-0 w-full h-full object-cover animate-[slow-zoom_25s_ease-in-out_infinite]" />
    <div class="absolute inset-0 bg-gradient-to-t md:bg-gradient-to-l from-[#1F1512] via-transparent to-transparent"></div>
  </div>
</div>

<style>
  @keyframes slow-zoom {
    0%, 100% { transform: scale(1); }
    50% { transform: scale(1.15); }
  }
</style>