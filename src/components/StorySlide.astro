---
interface Props {
  index: number;
  categoria: string;
  etiqueta: string;
  titulo: string;
  imagen: string;
  colorTexto: string;
  colorFondo: string;
  linkMapa?: string;
}
const { index, categoria, etiqueta, titulo, imagen, linkMapa } = Astro.props;
---

<div class="story-slide hidden absolute inset-0 flex-col md:flex-row cursor-pointer" data-index={index}>
  
  <div class="w-full md:w-1/2 h-1/2 md:h-full p-10 flex flex-col justify-center border-b md:border-b-0 md:border-r border-orange-200 bg-white/80 backdrop-blur-md">
    <span class="text-orange-500 font-bold uppercase tracking-widest text-sm mb-3">{etiqueta}</span>
    <h2 class="text-4xl md:text-6xl font-extrabold mb-6 leading-tight text-orange-950">{titulo}</h2>
    
    {linkMapa && (
      <a href={linkMapa} target="_blank" class="inline-block mt-2 px-6 py-3 bg-orange-100 hover:bg-orange-200 border border-orange-300 text-orange-800 font-bold rounded-2xl w-max transition-all hover:scale-105 shadow-sm">
        📍 Abrir en Maps
      </a>
    )}
    <p class="text-orange-400 mt-auto text-sm animate-pulse tracking-wide uppercase font-medium">Toca para continuar →</p>
  </div>

  <div class="w-full md:w-1/2 h-1/2 md:h-full relative overflow-hidden">
    <img 
      src={imagen} 
      style={index === 0 ? `view-transition-name: img-${categoria};` : ''}
      class="absolute inset-0 w-full h-full object-cover" 
    />
    <div class="absolute inset-0 bg-gradient-to-t md:bg-gradient-to-l from-orange-50 via-transparent to-transparent"></div>
  </div>
</div>