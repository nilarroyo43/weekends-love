---
interface Props {
  imagen: string;
}
const { imagen } = Astro.props;
---

<div id="splash-screen" class="fixed inset-0 z-50 flex flex-col items-center justify-center bg-orange-50 transition-opacity duration-1000 ease-in-out">
  
  <img 
    src={imagen} 
    alt="Cargando amor" 
    class="w-40 h-40 rounded-full shadow-2xl shadow-rose-200 object-cover animate-pulse mb-8 border-4 border-white" 
  />
  
  <p class="text-sm font-bold text-orange-400 tracking-[0.3em] uppercase animate-bounce">
    Always and forever...
  </p>
  
</div>

<script>
  document.addEventListener('astro:page-load', () => {
    const splash = document.getElementById('splash-screen');
    if (splash) {
      setTimeout(() => {
        splash.classList.add('opacity-0');
        setTimeout(() => { splash.remove(); }, 1000);
      }, 2000); 
    }
  });
</script>