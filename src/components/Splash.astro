---
// src/components/SplashScreen.astro
interface Props {
  imagen: string;
}

const { imagen } = Astro.props;
---

<div id="splash-screen" class="fixed inset-0 z-50 flex flex-col items-center justify-center bg-[#0a0a0a] transition-opacity duration-1000 ease-in-out">
  
  <img 
    src={imagen} 
    alt="Cargando amor" 
    class="w-40 h-40 rounded-full shadow-[0_0_40px_rgba(244,63,94,0.4)] object-cover animate-pulse mb-8 border-2 border-rose-900/50" 
  />
  
  <p class="text-xl font-medium text-rose-400 tracking-widest animate-bounce">
    Cargando amor...
  </p>
  
</div>

<script>
  // Lógica para desvanecer y eliminar la pantalla
  document.addEventListener('DOMContentLoaded', () => {
    const splash = document.getElementById('splash-screen');
    
    if (splash) {
      // Esperamos 2 segundos mostrando la pantalla
      setTimeout(() => {
        // Añadimos la clase de Tailwind para hacerla transparente (fade out)
        splash.classList.add('opacity-0');
        
        // Esperamos 1 segundo más (lo que dura la transición) y la borramos del HTML
        // Es vital borrarla (.remove()) para que no se quede invisible bloqueando los clics de los botones de abajo
        setTimeout(() => {
          splash.remove();
        }, 1000);
        
      }, 2000); 
    }
  });
</script>