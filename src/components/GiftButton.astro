---
// src/components/plan/GiftButton.astro
interface Props {
  categoria: string;
  imagen: string;
  label: string;
  colorBorde: string;
}

const { categoria, imagen, label, colorBorde } = Astro.props;
---

<div class="categoria-btn group relative w-40 h-40 mx-auto cursor-pointer" data-categoria={categoria}>
  <img 
    src={imagen} 
    class={`absolute inset-0 w-full h-full object-cover rounded-full border-4 shadow-xl transition-transform duration-500 group-hover:scale-105 ${colorBorde}`} 
    alt={label}
  />
  
  <div class="regalo-tapa absolute inset-0 z-10 flex items-center justify-center bg-rose-600 rounded-full border-4 border-rose-400 transition-all duration-700 ease-[cubic-bezier(0.34,1.56,0.64,1)] transform origin-bottom group-hover:-rotate-3 group-hover:scale-105">
    <span class="text-5xl drop-shadow-md">🎁</span>
  </div>
  
  <p class="absolute -bottom-10 left-1/2 -translate-x-1/2 font-bold text-gray-300 uppercase tracking-widest text-sm transition-colors group-hover:text-white">
    {label}
  </p>
</div>

<style>
  /* Clase que añade JS al hacer clic para que la tapa salga volando con estilo */
  :global(.tapa-abierta) {
    transform: translateY(-100px) rotate(20deg) scale(1.2) !important;
    opacity: 0 !important;
    pointer-events: none;
  }
</style>